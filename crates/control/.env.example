# ── label-control (C2) configuration ────────────────────────────────────────

# PostgreSQL (Azure Database for PostgreSQL Flexible Server in prod).
DATABASE_URL=postgres://user:pass@host:5432/labelhub

# Node-facing API — tailnet-only in production (the nodes reach it over the mesh).
NODE_API_BIND=0.0.0.0
NODE_API_PORT=9090

# Dashboard — fronted by EasyAuth (Entra) in production.
DASH_BIND=0.0.0.0
DASH_PORT=9091
# Folder with the dashboard SPA (defaults to ./web; set when running from the repo root).
DASH_WEB_DIR=web

# How the control plane reaches nodes: {scheme}://{hostname}:{mgmt_port}
NODE_SCHEME=http

# ── Tailscale OAuth client (mints tagged auth keys at enrollment) ────────────
# Create an OAuth client in the Tailscale admin console with the "auth_keys" scope
# and the tag owner for tag:lh-node. Optional — leave blank to skip key minting.
TS_OAUTH_CLIENT_ID=
TS_OAUTH_CLIENT_SECRET=
TS_TAILNET=example.com
TS_TAG=tag:lh-node

# ── Dev only ─────────────────────────────────────────────────────────────────
# When set, requests without an EasyAuth principal are treated as this admin.
# NEVER set in production (EasyAuth provides the identity there).
DEV_ADMIN=
