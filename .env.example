# ── label-hub configuration ─────────────────────────────────────────────────
# Copy to .env and edit. The .env file does most of the lifting.

# The hub runs TWO listeners:
#   PUBLIC — D365 webhook only, bound to loopback so only a tunnel sidecar on
#            this host can reach it.
#   LOCAL  — web console + management APIs, bound to the LAN (reach by mDNS name).

# Public/webhook listener (the tunnel forwards to this; keep it on loopback).
PUBLIC_BIND=127.0.0.1
PUBLIC_PORT=8080
# Your public tunnel/relay host, shown in the console's D365 guide (display only).
PUBLIC_URL=https://labels-plant1.example.com

# Local console listener (LAN-facing, relaxed — no secret needed on the LAN).
LOCAL_BIND=0.0.0.0
LOCAL_PORT=8081

# Advertise the console over mDNS so users can browse to http://printlabels.local:8081
MDNS_ENABLE=true
MDNS_HOSTNAME=printlabels

# Shared secret D365 must present on the inbound webhook.
# In D365 this is the External Service instance "Authentication secret"
# (referenced in the operation as $auth.secret$). Use a long random value.
INBOUND_SECRET=change-me-to-a-long-random-string

# Friendly label for this site/plant, shown in the console.
SITE_NAME=PLANT1

# Optional: printer used when an inbound job omits X-Printer-Name. Leave blank
# to require every job to name its printer.
DEFAULT_PRINTER=

# Default for the auto-print toggle on first run (operator can change it live).
# false = hold inbound labels in the queue for release; true = print on arrival.
AUTO_PRINT=false

# Where JSON state is persisted (printers/jobs/settings/config cache/creds).
DATA_DIR=data

# ── Optional: central control plane (C2) ─────────────────────────────────────
# When CONTROL_URL is set, the node enrolls and syncs its config (printers,
# settings, secret) from the control plane over the Tailscale mesh, and keeps a
# local cache so it still prints if the control plane is unreachable. Leave blank
# to run fully standalone from this .env.
CONTROL_URL=
ENROLLMENT_TOKEN=
HEARTBEAT_SECS=30
# Hostname reported to the C2 (defaults to the OS hostname / Tailscale MagicDNS name).
NODE_HOSTNAME=

# ── Optional: D365 OData (Entra ID app) for ad-hoc lookups ───────────────────
# Only needed for the optional manual-lookup feature. The core print path does
# not use these. Leave blank to disable.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
D365_BASE_URL=
D365_COMPANY=
