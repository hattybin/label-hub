# Label Hub node configuration — first-boot provisioning.
#
# After flashing the image, copy or rename this file to `labelhub.conf` on the
# FAT boot partition (visible from Windows / macOS / Linux). On first boot the
# node reads it, configures itself, and starts the service. The file is NOT
# deleted — it stays on the partition as a reference, but the provisioning
# service disables itself so it won't run again.
#
# If this file is absent, the node boots in standalone local mode and you can
# configure it via the Site Settings UI at http://labelhub.local:8081.

# ── Required ──────────────────────────────────────────────────────────────────

# Friendly site/plant name (shown in the Label Hub UI header).
SITE_NAME=PLANT1

# Shared secret for the D365 inbound webhook (bearer token).
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Use this same value in D365 External Service > Authentication secret.
INBOUND_SECRET=

# ── WiFi ─────────────────────────────────────────────────────────────────────

# Two-letter ISO 3166 country code. Sets the regulatory domain so the radio is
# not rfkill-blocked on boot. Default in the image is US; change if deploying
# in a different country.
WIFI_COUNTRY=US

# WiFi credentials (leave both blank if the Pi will use a wired connection).
WIFI_SSID=
WIFI_PASSWORD=

# ── SSH / access ──────────────────────────────────────────────────────────────

# SSH username created on first boot.
SSH_USER=labelhub

# SSH password (leave blank to disable password auth and use key auth only).
SSH_PASSWORD=labelhub

# Hostname for this node — it will be reachable at http://<HOSTNAME>.local:8081
HOSTNAME=labelhub

# ── Updates ───────────────────────────────────────────────────────────────────

# GitHub Personal Access Token (repo or contents:read scope).
# Stored at /etc/label-hub/github-pat (chmod 600, root-only).
# Required for future updates via the "Update to Latest" button or update.sh.
# Leave blank to skip — you can add it later via SSH.
GITHUB_PAT=

# ── Optional: D365 site filter ───────────────────────────────────────────────
# When running multiple hubs (one per plant/site), set this to the site or
# warehouse code this node should accept. Jobs whose X-Site header doesn't
# match are rejected with 422. Leave blank to accept jobs from any site.
# Add X-Site: <D365 field> to the D365 external service operation headers.
D365_SITE_FILTER=

# ── Optional: D365 OData integration ─────────────────────────────────────────
# Enables manual PO/receipt lookups in the receiving label form.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
D365_BASE_URL=
D365_COMPANY=

# ── Optional: public tunnel URL ───────────────────────────────────────────────
# Shown in the D365 External Service setup guide in Site Settings.
# Set this after you configure cloudflared / azbridge.
PUBLIC_URL=

# ── Optional: ports (defaults are fine) ──────────────────────────────────────
LOCAL_PORT=8081
PUBLIC_PORT=8080

# ── Optional: fleet control plane ────────────────────────────────────────────
# Leave blank for standalone mode (most common).
CONTROL_URL=
ENROLLMENT_TOKEN=

# ── Optional: Azure Relay Bridge (azbridge) ──────────────────────────────────
# Forwards the D365 webhook from Azure Relay to this node's public port.
# Requires the azbridge .deb to be included at image build time (3rd arg to build-image.sh).
# AZBRIDGE_CONNECTION_STRING: full SAS connection string from your Azure Relay namespace.
# AZBRIDGE_HC_NAME: the Hybrid Connection name (e.g. labelhub-print).
AZBRIDGE_CONNECTION_STRING=
AZBRIDGE_HC_NAME=

# ── Optional: Tailscale (needed for control plane mesh) ──────────────────────
# A tagged pre-authorized key (tag:lh-node) lets the device join unattended.
# If blank and CONTROL_URL is set, the control plane issues a key at enrollment.
TAILSCALE_AUTHKEY=
